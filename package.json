{
  "name": "apartment-finder",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint:check": "turbo run lint:check",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:write": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "knip": "DATABASE_URL=${DATABASE_URL:-postgres://ci:ci@localhost:5432/ci} knip --include files,binaries,duplicates,unlisted,unresolved",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "bun run --filter @apartment-finder/web db:generate",
    "db:push": "bun run --filter @apartment-finder/web db:push",
    "db:migrate": "bun run --filter @apartment-finder/web db:migrate",
    "db:reset": "bun run --filter @apartment-finder/web db:reset",
    "db:studio": "bun run --filter @apartment-finder/web db:studio",
    "db:check": "bun run scripts/check-migrations.ts",
    "email:dev": "bun run --filter @apartment-finder/web email:dev",
    "ci": "clear && bun run format:write && bun run lint:fix && bun run knip && bun run build && bun run test"
  },
  "devDependencies": {
    "knip": "^5.40.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}
