# =============================================================================
# Apartment Finder — environment variables
#
# Copy this file to `.env` at the repo root and fill in real values.
# `.env` is gitignored — DO NOT commit it. `.env.example` IS committed.
# =============================================================================

# ---- Postgres (required) ---------------------------------------------------
# We use Supabase only as hosted Postgres now (auth product replaced by Better Auth).
# Project Settings → Database → Connection string → "URI" (Transaction pooler, port 6543).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# ---- Better Auth (required) ------------------------------------------------
# 32+ char random secret. Generate with: `openssl rand -base64 32`
# Signs session cookies. Rotate it to force every session to log out.
BETTER_AUTH_SECRET=

# Public base URL Better Auth uses to construct callback URLs. Falls back to
# APP_PUBLIC_ORIGIN if unset.
#   Local: http://localhost:3000
#   Prod:  https://<your-vercel-host>
BETTER_AUTH_URL=

# ---- Google OAuth (required for "Continue with Google") --------------------
# 1) https://console.cloud.google.com/apis/credentials → Create credentials → OAuth client ID
# 2) Application type: "Web application"
# 3) Authorized redirect URIs (add ALL hosts you sign in from):
#      http://localhost:3000/api/auth/callback/google
#      https://<your-vercel-host>/api/auth/callback/google
# 4) Copy Client ID + Client secret below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Telegram Bot (required for alerts) ------------------------------------
# 1) Open @BotFather on Telegram, /newbot, follow prompts.
# 2) BotFather gives you a token — paste below.
TELEGRAM_BOT_TOKEN=

# Random string you generate. Telegram echoes it in the
# X-Telegram-Bot-Api-Secret-Token header on webhook callbacks.
TELEGRAM_WEBHOOK_SECRET=

# Bot username (without @). Used to build t.me/<username>?start=<token> deep
# links so users can link their Telegram chat from the preferences page.
TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Public site URL used in alert emails (e.g. "https://apartment-finder.vercel.app").
# Alert emails link back to /listings/<id> on this origin.
NEXT_PUBLIC_SITE_URL=

# ---- Vercel AI Gateway (required for AI scoring) ---------------------------
# Vercel dashboard → AI Gateway → create API key.
AI_GATEWAY_API_KEY=

# ---- Vercel Cron auth (required when deployed to Vercel) -------------------
# Random string. Vercel signs cron requests with `Authorization: Bearer <this>`.
# Set the SAME value in Vercel env vars and locally.
CRON_SECRET=

# ---- Apify (Phase 3 — Facebook groups scraping) ----------------------------
APIFY_TOKEN=
APIFY_WEBHOOK_SECRET=

# Public https origin Apify can POST to (use Vercel URL or ngrok in dev).
# Example: https://your-app.vercel.app  or  https://abc123.ngrok-free.app
APP_PUBLIC_ORIGIN=

# ---- Chrome Extension ingest (Phase 5) -------------------------------------
# Random string. Extension sends in `x-extension-ingest-secret` header;
# `/api/webhooks/extension` rejects mismatches. Configure the same value in
# the extension's options page after install.
EXTENSION_INGEST_SECRET=

# ---- Resend (magic-link emails + alert emails) -----------------------------
# Required for sign-in via magic link. Also used for listing alert emails.
# 1) https://resend.com → verify your sending domain (DNS records).
# 2) Settings → API Keys → create.
# 3) RESEND_FROM_EMAIL must be from a verified domain or magic links 403.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Apartment Finder <noreply@your-domain.com>
ADMIN_SUMMARY_EMAILS=admin@example.com

# ---- Yad2 IL-region proxy --------------------------------------------------
# Yad2 blocks non-Israel IPs. Deploy services/yad2-proxy/ to me-west1 (Tel Aviv)
# and set both vars. When unset, the scraper calls Yad2 directly (only works
# from Israeli IPs). See services/yad2-proxy/README.md.
YAD2_PROXY_URL=
YAD2_PROXY_SECRET=

# ---- Node env --------------------------------------------------------------
NODE_ENV=development
