# =============================================================================
# Apartment Finder — environment variables
#
# Copy this file to `.env` at the repo root and fill in real values.
# `.env` is gitignored — DO NOT commit it. `.env.example` IS committed.
# =============================================================================

# ---- Supabase (Phase 1 required) -------------------------------------------
# Create a project at https://supabase.com/dashboard/new
# Then Project Settings -> Database -> Connection string -> "URI" (pooler)
# Use the "Transaction" pooler URL for serverless (port 6543).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Phase 4 — browser-side Supabase (magic-link auth for dashboard).
# Same values as SUPABASE_URL / SUPABASE_ANON_KEY above.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ---- Telegram Bot (Phase 1 required for alerts) ----------------------------
# 1) Open @BotFather on Telegram, /newbot, follow prompts.
# 2) BotFather gives you a token — paste below.
TELEGRAM_BOT_TOKEN=<bot-token>

# Random string you generate. Vercel → Project Settings → Environment Variables.
# Telegram must send this back in the X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET=<random-32-char-string>

# Optional fallback: if preferences don't yet have a chat_id, alerts go here.
# You'll learn your chat_id by /start'ing the bot after deploy.
TELEGRAM_ALLOWED_CHAT_ID=

# ---- Vercel AI Gateway (Phase 2 required; unused in Phase 1) ---------------
# Enable AI Gateway in your Vercel dashboard, create a key.
AI_GATEWAY_API_KEY=

# ---- Vercel Cron auth (Phase 1 required on Vercel) -------------------------
# Random string. Vercel signs cron requests with Authorization: Bearer <this>.
# Set the SAME value in Vercel env vars as you set locally.
CRON_SECRET=<random-32-char-string>

# ---- Apify (Phase 3) -------------------------------------------------------
APIFY_TOKEN=
APIFY_WEBHOOK_SECRET=

# ---- Chrome Extension ingest (Phase 5) -------------------------------------
# Random string you generate. The extension sends this in the
# `x-extension-ingest-secret` header; /api/webhooks/extension rejects mismatches.
# Configure the same value in the extension's options page after install.
EXTENSION_INGEST_SECRET=<random-32-char-string>

# ---- Resend (Phase 4) ------------------------------------------------------
RESEND_API_KEY=

# ---- Node env --------------------------------------------------------------
NODE_ENV=development
