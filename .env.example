# =============================================================================
# Apartment Finder — environment variables
#
# Copy this file to `.env` at the repo root and fill in real values.
# `.env` is gitignored — DO NOT commit it. `.env.example` IS committed.
# =============================================================================

# ---- Postgres (required) ---------------------------------------------------
# Supabase project → Database → Connection string → "URI" (Transaction pooler, port 6543).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# pgvector ≥ 0.7 must be enabled (Supabase enables it by default).
DATABASE_URL=

# ---- Better Auth (required) ------------------------------------------------
# 32+ char random secret. `openssl rand -base64 32`
BETTER_AUTH_SECRET=

# Public base URL Better Auth uses to construct callback URLs. Falls back to
# APP_PUBLIC_ORIGIN if unset.
#   Local: http://localhost:3000
#   Prod:  https://<your-vercel-host>
BETTER_AUTH_URL=

# ---- Google OAuth (required for "Continue with Google") --------------------
# https://console.cloud.google.com/apis/credentials → OAuth client ID (Web).
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-vercel-host>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public site URL used in alert emails (e.g. "https://apartment-finder.vercel.app").
NEXT_PUBLIC_SITE_URL=

# ---- Vercel AI Gateway (required for AI extraction + embeddings) -----------
# Vercel dashboard → AI Gateway → create API key.
AI_GATEWAY_API_KEY=

# ---- Vercel Cron auth ------------------------------------------------------
# Vercel signs cron requests with `Authorization: Bearer <this>`.
CRON_SECRET=

# ---- Google Geocoding (required for address normalization) -----------------
# https://console.cloud.google.com/apis/credentials → API key with Geocoding API enabled.
GOOGLE_GEOCODING_API_KEY=

# ---- Apify (Facebook groups scraping) --------------------------------------
APIFY_TOKEN=
APIFY_WEBHOOK_SECRET=

# Public https origin Apify can POST to (use Vercel URL or ngrok in dev).
APP_PUBLIC_ORIGIN=

# Comma-separated list of Facebook group URLs to scrape.
FACEBOOK_GROUP_URLS=

# ---- Resend (magic-link emails + alert emails) -----------------------------
# https://resend.com → verify domain → API key.
# RESEND_FROM_EMAIL must be from a verified domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Apartment Finder <noreply@your-domain.com>

# ---- Yad2 IL-region proxy --------------------------------------------------
# Yad2 blocks non-Israel IPs. Deploy services/yad2-proxy/ to me-west1.
YAD2_PROXY_URL=
YAD2_PROXY_SECRET=

# ---- Node env --------------------------------------------------------------
NODE_ENV=development
