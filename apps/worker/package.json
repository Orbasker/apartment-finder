{
  "name": "@apartment-finder/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run src/index.ts",
    "start": "bun --env-file=../../.env run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target=bun",
