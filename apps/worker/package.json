    "test": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@apartment-finder/queue": "workspace:*",
    "@apartment-finder/shared": "workspace:*",
    "@react-email/components": "^0.0.35",
    "@react-email/render": "^1.0.4",
    "@vercel/blob": "^0.27.0",
    "@ai-sdk/gateway": "^1.0.0",
    "ai": "^5.0.0",
    "bullmq": "^5.40.0",
    "drizzle-orm": "^0.36.4",
    "grammy": "^1.42.0",
    "ioredis": "^5.4.0",
    "postgres": "^3.4.5",
    "react": "19.0.0",
    "resend": "6.12.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "^22.10.2",
    "@types/react": "19.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
