# Database
DATABASE_URL=postgres://user:password@host:5432/dbname

# Auth (Better Auth)
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=https://your-domain.vercel.app

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Admin
ADMIN_EMAIL=

# AI Gateway (Gemini extraction + embeddings)
AI_GATEWAY_API_KEY=

# Public site URL
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Cron
CRON_SECRET=

# Apify (Facebook group scraping)
APIFY_TOKEN=
APIFY_WEBHOOK_SECRET=
APP_PUBLIC_ORIGIN=https://your-domain.vercel.app
APIFY_GROUPS=https://www.facebook.com/groups/group1;https://www.facebook.com/groups/group2

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Google Geocoding (server-only, IP-restricted)
GOOGLE_GEOCODING_API_KEY=

# Google Maps JS (browser-exposed, restrict by HTTP referrer in GCP)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Yad2 proxy
YAD2_PROXY_URL=https://your-proxy.run.app
YAD2_PROXY_SECRET=

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# BullMQ / APA-24 async collectors
REDIS_URL=rediss://default:password@hostname:6379
COLLECTOR_WEBHOOK_SECRET=
BLOB_READ_WRITE_TOKEN=
USE_BULLMQ_COLLECTORS=false
