{
  "name": "@apartment-finder/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:manual": "bun scripts/apply-manual-migrations.ts",
    "db:push": "bun run db:manual && drizzle-kit push",
    "db:push:auto": "bun run db:manual && DRIZZLE_PUSH_NO_STRICT=1 drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^1.0.0",
    "@ai-sdk/react": "3.0.170",
    "@apartment-finder/shared": "workspace:*",
    "@tailwindcss/postcss": "4.2.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^5.0.0",
    "better-auth": "^1.6.9",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "^0.36.4",
    "grammy": "^1.33.0",
    "lucide-react": "1.8.0",
    "next": "^15.5.0",
    "postgres": "^3.4.5",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "resend": "6.12.2",
    "tailwind-merge": "3.5.0",
