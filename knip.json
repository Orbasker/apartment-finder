{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts"],
      "project": ["scripts/**/*.ts"]
    },
    "apps/web": {
      "entry": [
        "app/**/{page,layout,loading,error,not-found,template,route,default}.{ts,tsx}",
        "middleware.ts",
        "next.config.ts",
        "drizzle.config.ts",
        "postcss.config.mjs",
        "eslint.config.mjs",
        "src/**/*.test.ts"
      ],
      "project": ["**/*.{ts,tsx}"],
      "ignore": ["next-env.d.ts", ".next/**", "drizzle/**"],
      "ignoreDependencies": [
        "tailwindcss",
        "@tailwindcss/postcss",
        "postcss",
        "eslint-config-next",
        "@next/eslint-plugin-next",
        "@typescript-eslint/eslint-plugin",
        "@typescript-eslint/parser",
        "eslint-import-resolver-typescript",
        "eslint-plugin-import",
        "eslint-plugin-jsx-a11y",
        "eslint-plugin-react",
        "eslint-plugin-react-hooks",
        "@eslint/eslintrc",
        "lucide-react"
      ]
    },
    "packages/shared": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
