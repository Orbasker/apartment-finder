{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts"],
      "project": ["scripts/**/*.ts"]
    },
    "apps/web": {
      "entry": [
        "app/**/{page,layout,loading,error,not-found,template,route,default}.{ts,tsx}",
        "src/**/*.test.ts",
        "scripts/**/*.ts"
      ],
      "project": ["**/*.{ts,tsx}"],
      "ignoreDependencies": ["postcss"]
    },
    "packages/shared": {
      "project": ["src/**/*.ts"]
    },
    "packages/queue": {
      "project": ["src/**/*.ts"]
    }
  }
}
