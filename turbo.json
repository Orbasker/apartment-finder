{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": [
    "ADMIN_SUMMARY_EMAILS",
    "AI_GATEWAY_API_KEY",
    "APIFY_TOKEN",
    "APIFY_WEBHOOK_SECRET",
    "APP_PUBLIC_ORIGIN",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "CRON_SECRET",
    "DATABASE_URL",
    "DIRECT_URL",
    "EXTENSION_INGEST_SECRET",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_TELEGRAM_BOT_USERNAME",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "TELEGRAM_BOT_TOKEN",
    "TELEGRAM_BOT_USERNAME",
    "TELEGRAM_WEBHOOK_SECRET",
    "YAD2_PROXY_SECRET",
    "YAD2_PROXY_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:push:auto": {
      "cache": false
    }
  }
}
