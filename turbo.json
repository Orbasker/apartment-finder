{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": [
    "AI_GATEWAY_API_KEY",
    "APIFY_TOKEN",
    "APIFY_WEBHOOK_SECRET",
    "APP_PUBLIC_ORIGIN",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "CRON_SECRET",
    "DATABASE_URL",
    "DIRECT_URL",
    "FACEBOOK_GROUP_URLS",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GOOGLE_GEOCODING_API_KEY",
    "NEXT_PUBLIC_SITE_URL",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "SUPABASE_ANON_KEY",
    "SUPABASE_DATABASE_PASSWORD",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_URL",
    "YAD2_PROXY_SECRET",
    "YAD2_PROXY_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "lint:check": {},
    "lint:fix": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    }
  }
}
